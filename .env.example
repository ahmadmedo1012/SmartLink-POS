# Database (Neon PostgreSQL — get from console.neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Auth secrets (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="change-me-to-a-random-secret"
AUTH_SECRET="change-me-to-a-random-secret"

# Optional — set to your production URL
NEXTAUTH_URL="https://your-app.onrender.com"
